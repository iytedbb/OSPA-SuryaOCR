# OSPA SuryaOCR Environment Variables

# Application
SECRET_KEY=change-this-to-a-secure-random-string
FLASK_ENV=production
FLASK_DEBUG=False
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# Database Configuration (Used by Docker automatically if uncommented)
# If DB_PASSWORD and DB_NAME are empty, the app falls back to local SQLite Database (app.db)
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=surya_ocr_secret
DB_NAME=ospa_suryaocr

# GPU Options
CUDA_VISIBLE_DEVICES=0
TORCH_CUDA_ARCH_LIST=8.6

# System Paths (Optional overrides)
# UPLOADS_DIR=uploads
# OUTPUTS_DIR=outputs
# MODELS_DIR=models
# LOGS_DIR=logs
